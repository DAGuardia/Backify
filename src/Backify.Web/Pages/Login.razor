@page "/"
@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Backify – Login</PageTitle>

<div class="login-page">
    <div class="login-box">
        <div class="login-logo">
            <h1>Backify</h1>
            <p>For those with a musical past before Spotify.<br />Bring your Last.fm music history to Spotify.<br />Like the songs you've loved for years.<br />Add your most played albums to your Spotify library.<br />Help Spotify's algorithm know you better — build your library from years of real listening history.</p>
        </div>

        <div class="how-it-works">
            <div class="hiw-step">
                <div class="hiw-icon">①</div>
                <div>
                    <div class="hiw-title">Connect your accounts</div>
                    <div class="hiw-desc">Link your Last.fm and Spotify accounts. Nothing is stored after your session ends.</div>
                </div>
            </div>
            <div class="hiw-step">
                <div class="hiw-icon">②</div>
                <div>
                    <div class="hiw-title">Preview your top music</div>
                    <div class="hiw-desc">Backify fetches your most-played tracks and albums from Last.fm and finds them on Spotify.</div>
                </div>
            </div>
            <div class="hiw-step">
                <div class="hiw-icon">③</div>
                <div>
                    <div class="hiw-title">Sync to your library</div>
                    <div class="hiw-desc">Choose what to keep and like your songs or save your albums to your Spotify library in one click.</div>
                </div>
            </div>
        </div>

        <div class="login-card">
            <h2>Connect your accounts</h2>
            <p>Both connections are required. Tokens are stored securely on the server and never persist beyond your session.</p>

            @if (_loading)
            {
                <div class="skeleton skeleton-btn"></div>
                <div class="skeleton skeleton-btn"></div>
            }
            else
            {
                <!-- Last.fm button -->
                <a href="@(_lfmConnected ? null : $"{Http.BaseAddress}auth/lastfm")"
                   class="auth-btn @(_lfmConnected ? "connected" : "")">
                    <div class="auth-btn-left">
                        <div class="auth-btn-icon lastfm">∫</div>
                        <div>
                            <div class="auth-btn-title">Last.fm</div>
                            <div class="auth-btn-sub">
                                @(_lfmConnected ? $"Connected as {_lfmUsername}" : "Connect your account")
                            </div>
                        </div>
                    </div>
                    @if (_lfmConnected) { <span class="check">✓</span> }
                    else { <span class="chevron">›</span> }
                </a>

                <!-- Spotify button -->
                <a href="@(_spConnected ? null : $"{Http.BaseAddress}auth/spotify")"
                   class="auth-btn @(_spConnected ? "connected" : "")">
                    <div class="auth-btn-left">
                        <div class="auth-btn-icon spotify">
                            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                            </svg>
                        </div>
                        <div>
                            <div class="auth-btn-title">Spotify</div>
                            <div class="auth-btn-sub">@(_spConnected ? "Connected" : "Connect your account")</div>
                        </div>
                    </div>
                    @if (_spConnected) { <span class="check">✓</span> }
                    else { <span class="chevron">›</span> }
                </a>
            }

            @if (_error != null)
            {
                <div class="error-msg">
                    @(_error switch {
                        "lastfm_failed" => "Failed to connect Last.fm. Please try again.",
                        "spotify_denied" => "Spotify connection was denied.",
                        "spotify_failed" => "Failed to connect Spotify. Please try again.",
                        _ => "An error occurred. Please try again."
                    })
                </div>
            }

            @if (_lfmConnected && !_spConnected)
            {
                <div class="status-hint">Last.fm connected! Now connect Spotify to continue.</div>
            }
            @if (!_lfmConnected && _spConnected)
            {
                <div class="status-hint">Spotify connected! Now connect Last.fm to continue.</div>
            }

        </div>

        <div class="spotify-limitation-notice">
            <span class="limitation-icon">⚠️</span>
            <div>
                <strong>Spotify API Limitation</strong><br />
                Due to Spotify's API restrictions, this app runs in <strong>development mode</strong> and only <strong>25 accounts</strong> can use it — each must be manually allowlisted. To use it without restrictions, run it locally with your own API keys — the link to the repository is below.
            </div>
        </div>

    </div>
</div>

@code {
    bool _loading = true;
    bool _lfmConnected;
    bool _spConnected;
    string? _lfmUsername;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        // Check for error in URL
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _error = query.TryGetValue("error", out var e) ? e.ToString() : null;

        try
        {
            var session = await Http.GetFromJsonAsync<SessionInfo>("session");
            if (session != null)
            {
                _lfmConnected = session.LastFmConnected;
                _spConnected = session.SpotifyConnected;
                _lfmUsername = session.LastFmUsername;

                if (_lfmConnected && _spConnected)
                    Nav.NavigateTo("/dashboard");
            }
        }
        catch { }
        finally { _loading = false; }
    }

    record SessionInfo(bool LastFmConnected, bool SpotifyConnected, string? LastFmUsername);
}
