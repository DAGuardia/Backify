@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="card">
    <div class="card-header">
        <div>
            <div class="card-title">@(IsTrack ? "Top Songs" : IsArtist ? "Top Artists" : "Top Albums")</div>
            <div class="card-desc">@(IsTrack ? "Like your most-played tracks on Spotify" : IsArtist ? "Follow your most-listened artists on Spotify" : "Save your most-played albums to your Spotify library")</div>
        </div>
        <div class="card-icon @(IsTrack ? "tracks" : IsArtist ? "artists" : "albums")">@(IsTrack ? "♥" : IsArtist ? "★" : "◉")</div>
    </div>

    <!-- Controls -->
    <div class="controls">
        <div class="control-group">
            <label class="control-label">
                Top <span>@N</span> @(IsTrack ? "tracks" : IsArtist ? "artists" : "albums")
            </label>
            <input type="range" min="1" max="@MaxN" @bind="N" @bind:event="oninput"
                   disabled="@IsBusy" />
            <div class="range-hints"><span>1</span><span>@MaxN</span></div>
        </div>
        <div class="control-group" style="max-width:200px">
            <label class="control-label">Time period</label>
            <select @bind="Period" disabled="@IsBusy">
                <option value="overall">All time</option>
                <option value="12month">Last 12 months</option>
                <option value="6month">Last 6 months</option>
                <option value="3month">Last 3 months</option>
                <option value="1month">Last month</option>
                <option value="7day">Last 7 days</option>
            </select>
        </div>
        @if (IsTrack)
        {
            <div class="control-group" style="max-width:130px">
                <label class="control-label">Start from rank</label>
                <input type="number" min="1" max="@MaxN" @bind="_searchFrom" disabled="@IsBusy"
                       style="width:100%;padding:.35rem .5rem;background:var(--input-bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:.875rem" />
            </div>
        }
    </div>

    <!-- Buttons -->
    @if (Status != SyncStatus.Done)
    {
        <div class="btn-row">
            <button class="btn btn-preview" @onclick="HandlePreview" disabled="@IsBusy">
                @if (Status == SyncStatus.Previewing)
                {
                    <div class="spinner"></div>
                    <span>Searching...@(_totalToSearch > 0 ? $" {_searchedCount}/{_totalToSearch}" : "")</span>
                }
                else
                {
                    <span>Preview</span>
                }
            </button>
            @if (Status == SyncStatus.PreviewDone && FoundCount > 0)
            {
                <button class="btn @ApplyBtnClass" @onclick="HandleApply" disabled="@(SelectedFoundCount == 0)">
                    @(IsTrack ? $"Like {SelectedFoundCount} Songs" : IsArtist ? $"Follow {SelectedFoundCount} Artists" : $"Save {SelectedFoundCount} Albums")
                </button>
            }
        </div>
        @if (Status == SyncStatus.PreviewDone && FoundCount > 0)
        {
            <div class="selection-row">
                <button class="btn-link" @onclick="SelectAll">Select all</button>
                <span class="sep">·</span>
                <button class="btn-link" @onclick="DeselectAll">Deselect all</button>
                <span class="selection-count">@SelectedFoundCount of @FoundCount selected</span>
                @if (_previewRateLimited)
                {
                    <button class="btn-link" style="margin-left:auto;color:#fbbf24" @onclick="TriggerRetrySearch">Retry unmatched</button>
                }
            </div>
        }
    }

    <!-- Done banner -->
    @if (Status == SyncStatus.Done)
    {
        <div class="done-banner">
            <div class="done-text">
                <span>✓</span>
                <span>@(IsTrack ? $"{Progress.Total} songs liked!" : IsArtist ? $"{Progress.Total} artists followed!" : $"{Progress.Total} albums saved!")</span>
            </div>
            <button class="btn-reset" @onclick="Reset">Start over</button>
        </div>
    }

    <!-- Error -->
    @if (Status == SyncStatus.Error && ErrorMessage != null)
    {
        <div class="error-banner">
            <div>@ErrorMessage</div>
            <div style="margin-top:.5rem;display:flex;gap:.75rem;align-items:center">
                @if (RemainingCount > 0)
                {
                    <button class="btn-reset" style="text-decoration:underline" @onclick="HandleRetry">
                        Retry (@RemainingCount remaining)
                    </button>
                }
                <button class="btn-reset" style="text-decoration:underline" @onclick="Reset">Start over</button>
            </div>
        </div>
    }

    <!-- Progress during apply -->
    @if (Status == SyncStatus.Applying)
    {
        <ProgressBar Done="Progress.Done" Total="Progress.Total"
                     Label="@(IsTrack ? "Liking songs on Spotify..." : IsArtist ? "Following artists on Spotify..." : "Saving albums to Spotify...")" />
    }

    <!-- Rate limit countdown -->
    @if (Status == SyncStatus.RateLimited)
    {
        var pct = _countdownTotal > 0 ? (int)((double)_countdownSeconds / _countdownTotal * 100) : 0;
        <div class="ratelimit-banner">
            <div class="ratelimit-text">
                <span>Spotify is limiting requests — resuming in <strong>@FormatCountdown(_countdownSeconds)</strong></span>
                <button class="btn-reset" style="text-decoration:underline;margin-left:.75rem" @onclick="CancelCountdown">Cancel</button>
            </div>
            <div class="progress-track" style="margin-top:.5rem">
                <div class="progress-fill ratelimit-fill" style="width:@(pct)%;transition:width 1s linear"></div>
            </div>
        </div>
        @if (_syncIds.Count > 0)
        {
            <ProgressBar Done="Progress.Done" Total="Progress.Total" Label="Paused — waiting for Spotify..." />
        }
    }

    <!-- Preview table -->
    @if (Results.Count > 0 && Status is not SyncStatus.Idle)
    {
        <PreviewTable Items="Results" Type="@Type"
                      Selected="_selected"
                      SyncedIds="_syncedIds"
                      Phase="TablePhaseFromStatus()"
                      OnToggle="ToggleSelected" />
    }
</div>

@code {
    [Parameter] public string Type { get; set; } = "tracks";

    bool IsTrack => Type == "tracks";
    bool IsArtist => Type == "artists";
    int MaxN => IsTrack ? 1000 : 500;
    string ApplyBtnClass => IsTrack ? "btn-apply-tracks" : IsArtist ? "btn-apply-artists" : "btn-apply-albums";
    bool IsBusy => Status is SyncStatus.Previewing or SyncStatus.Applying or SyncStatus.RateLimited;

    int N = 0;
    string Period = "overall";
    SyncStatus Status = SyncStatus.Idle;
    List<PreviewTable.PreviewItemDto> Results = new();
    (int Done, int Total) Progress = (0, 0);
    string? ErrorMessage;
    HashSet<string> _selected = new();
    HashSet<string> _syncedIds = new();
    List<string> _syncIds = new();
    bool _previewRateLimited = false;
    int _countdownSeconds = 0;
    int _countdownTotal = 0;
    CancellationTokenSource? _countdownCts;
    List<PreviewTable.PreviewItemDto> _pendingSearch = new();
    HashSet<int> _searchedRanks = new();
    int _searchedCount = 0;
    int _totalToSearch = 0;
    int _searchFrom = 1;

    int FoundCount => Results.Count(r => r.Found && r.SpotifyId != null);
    int SelectedFoundCount => Results.Count(r => r.Found && r.SpotifyId != null && _selected.Contains(r.SpotifyId!));
    int RemainingCount => _syncIds.Count - Progress.Done;

    protected override void OnInitialized()
    {
        N = IsTrack ? 1000 : 500;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var saved = await LoadListAsync();
        if (saved == null || saved.Items.Count == 0) return;

        N = saved.N;
        Period = saved.Period;

        var cache = await LoadCacheAsync();
        Results = saved.Items.Select(i =>
        {
            var key = CacheKey(i.Name, i.Artist);
            return cache.TryGetValue(key, out var spotifyId)
                ? new PreviewTable.PreviewItemDto(i.Rank, i.Name, i.Artist, i.PlayCount, spotifyId, true, PreviewTable.SearchItemStatus.Done)
                : new PreviewTable.PreviewItemDto(i.Rank, i.Name, i.Artist, i.PlayCount, null, false, PreviewTable.SearchItemStatus.Pending);
        }).ToList();
        _selected = Results.Where(r => r.Found && r.SpotifyId != null).Select(r => r.SpotifyId!).ToHashSet();
        var excluded = await LoadExcludedAsync();
        foreach (var id in excluded) _selected.Remove(id);
        _searchedRanks = Results.Where(r => r.SearchStatus == PreviewTable.SearchItemStatus.Done).Select(r => r.Rank).ToHashSet();
        _searchedCount = _searchedRanks.Count;
        _totalToSearch = Results.Count(r => r.SearchStatus == PreviewTable.SearchItemStatus.Pending);
        _syncedIds = await LoadSyncedAsync();
        Status = SyncStatus.PreviewDone;
        StateHasChanged();
    }


    PreviewTable.TablePhase TablePhaseFromStatus() => Status switch
    {
        SyncStatus.Applying => PreviewTable.TablePhase.Applying,
        SyncStatus.RateLimited => _syncIds.Count > 0 ? PreviewTable.TablePhase.Applying : PreviewTable.TablePhase.Preview,
        SyncStatus.Done or SyncStatus.Error => PreviewTable.TablePhase.Done,
        _ => PreviewTable.TablePhase.Preview,
    };

    void ToggleSelected(string id)
    {
        if (!_selected.Add(id)) _selected.Remove(id);
        _ = SaveExcludedAsync();
    }

    void SelectAll()
    {
        foreach (var r in Results.Where(r => r.Found && r.SpotifyId != null))
            _selected.Add(r.SpotifyId!);
        _ = SaveExcludedAsync();
    }

    void DeselectAll()
    {
        _selected.Clear();
        _ = SaveExcludedAsync();
    }

    async Task HandlePreview()
    {
        Status = SyncStatus.Previewing;
        Results = new();
        _selected = new();
        _syncedIds = new();
        _syncIds = new();
        _previewRateLimited = false;
        _searchedRanks = new();
        _searchedCount = 0;
        _totalToSearch = 0;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            // 1. Fetch Last.fm list
            var lfmItems = await Http.GetFromJsonAsync<List<ApiPreviewItem>>($"{Type}/list?n={N}&period={Period}");
            await SaveListAsync(lfmItems!, N, Period);

            // 2. Apply cache — pre-populate found items, pending for the rest
            var cache = await LoadCacheAsync();
            Results = lfmItems!.Select(i =>
            {
                var key = CacheKey(i.Name, i.Artist);
                return cache.TryGetValue(key, out var spotifyId)
                    ? new PreviewTable.PreviewItemDto(i.Rank, i.Name, i.Artist, i.PlayCount, spotifyId, true, PreviewTable.SearchItemStatus.Done)
                    : new PreviewTable.PreviewItemDto(i.Rank, i.Name, i.Artist, i.PlayCount, null, false, PreviewTable.SearchItemStatus.Pending);
            }).ToList();
            _selected = Results.Where(r => r.Found && r.SpotifyId != null).Select(r => r.SpotifyId!).ToHashSet();
            var excluded = await LoadExcludedAsync();
            foreach (var id in excluded) _selected.Remove(id);
            _searchedRanks = Results.Where(r => r.SearchStatus == PreviewTable.SearchItemStatus.Done).Select(r => r.Rank).ToHashSet();
            StateHasChanged();

            // 3. Stream search for uncached items (tracks: respect _searchFrom offset)
            _pendingSearch = Results.Where(r => r.SearchStatus == PreviewTable.SearchItemStatus.Pending
                && (!IsTrack || r.Rank >= _searchFrom)).ToList();
            _totalToSearch = _pendingSearch.Count;

            if (_pendingSearch.Count == 0) { Status = SyncStatus.PreviewDone; return; }

            await StreamSearch(_pendingSearch);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Status = SyncStatus.Error;
            StateHasChanged();
        }
    }

    async Task StreamSearch(List<PreviewTable.PreviewItemDto> items)
    {
        Status = SyncStatus.Previewing;
        var searchedInThisStream = new HashSet<int>();

        var request = new System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Post,
            $"{Http.BaseAddress}{Type}/search-stream");
        request.Content = System.Net.Http.Json.JsonContent.Create(
            items.Select(r => new { r.Rank, r.Name, r.Artist, r.PlayCount }).ToList());

        try
        {
            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();
            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new System.IO.StreamReader(stream);

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (string.IsNullOrEmpty(line) || !line.StartsWith("data: ")) continue;

                var json = line["data: ".Length..];
                var evt = System.Text.Json.JsonSerializer.Deserialize<SearchEventDto>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (evt == null) continue;

                switch (evt.Type)
                {
                    case "searching":
                        SetItemSearchStatus(evt.Item!.Rank, PreviewTable.SearchItemStatus.Searching);
                        await InvokeAsync(StateHasChanged);
                        break;

                    case "result":
                        var r = evt.Item!;
                        searchedInThisStream.Add(r.Rank);
                        _searchedRanks.Add(r.Rank);
                        _searchedCount++;
                        Results = Results.Select(x => x.Rank == r.Rank
                            ? x with { SpotifyId = r.SpotifyId, Found = r.Found, SearchStatus = PreviewTable.SearchItemStatus.Done }
                            : x).ToList();
                        if (r.Found && r.SpotifyId != null) _selected.Add(r.SpotifyId);
                        await SaveCacheAsync();
                        await InvokeAsync(StateHasChanged);
                        break;

                    case "ratelimit":
                        _pendingSearch = items.Where(x => !searchedInThisStream.Contains(x.Rank)).ToList();
                        await InvokeAsync(StateHasChanged);
                        await StartCountdown(
                            evt.WaitSeconds + 2,
                            async () => { await StreamSearch(_pendingSearch); return 0; },
                            () => { Status = SyncStatus.PreviewDone; _previewRateLimited = true; InvokeAsync(StateHasChanged); }
                        );
                        return;

                    case "error":
                        ErrorMessage = evt.ErrorMessage ?? "An error occurred. Please log out and log back in.";
                        Status = SyncStatus.Error;
                        await InvokeAsync(StateHasChanged);
                        return;

                    case "done":
                        Status = SyncStatus.PreviewDone;
                        await InvokeAsync(StateHasChanged);
                        return;
                }
            }

            if (Status == SyncStatus.Previewing) Status = SyncStatus.PreviewDone;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Status = SyncStatus.Error;
        }
        StateHasChanged();
    }

    void SetItemSearchStatus(int rank, PreviewTable.SearchItemStatus status)
        => Results = Results.Select(r => r.Rank == rank ? r with { SearchStatus = status } : r).ToList();

    async Task TriggerRetrySearch()
    {
        if (_pendingSearch.Count == 0)
            _pendingSearch = Results.Where(r => r.SearchStatus != PreviewTable.SearchItemStatus.Done || !r.Found)
                .Where(r => !_searchedRanks.Contains(r.Rank)).ToList();
        await StreamSearch(_pendingSearch);
    }

    async Task HandleApply()
    {
        _syncIds = Results
            .Where(r => r.Found && r.SpotifyId != null && _selected.Contains(r.SpotifyId!) && !_syncedIds.Contains(r.SpotifyId!))
            .Select(r => r.SpotifyId!)
            .ToList();
        var waitSeconds = await RunSync(0);
        if (waitSeconds > 0) await StartCountdown(waitSeconds, () => RunSync(Progress.Done));
    }

    async Task HandleRetry()
    {
        var waitSeconds = await RunSync(Progress.Done);
        if (waitSeconds > 0) await StartCountdown(waitSeconds, () => RunSync(Progress.Done));
    }

    async Task StartCountdown(int seconds, Func<Task<int>> onComplete, Action? onCancel = null)
    {
        _countdownSeconds = seconds;
        _countdownTotal = seconds;
        Status = SyncStatus.RateLimited;
        _countdownCts = new CancellationTokenSource();
        try
        {
            while (_countdownSeconds > 0)
            {
                StateHasChanged();
                await Task.Delay(1000, _countdownCts.Token);
                _countdownSeconds--;
            }
            StateHasChanged();
            var waitAgain = await onComplete();
            if (waitAgain > 0) await StartCountdown(waitAgain, onComplete, onCancel);
        }
        catch (OperationCanceledException)
        {
            if (onCancel != null)
                onCancel();
            else
            {
                Status = SyncStatus.Error;
                ErrorMessage = "Sync paused — resume when ready.";
                StateHasChanged();
            }
        }
    }

    void CancelCountdown() => _countdownCts?.Cancel();

    async Task<int> RunSync(int startFrom)
    {
        var toSync = _syncIds.Skip(startFrom).ToList();
        if (toSync.Count == 0) return 0;

        Status = SyncStatus.Applying;
        Progress = (startFrom, _syncIds.Count);
        ErrorMessage = null;
        StateHasChanged();

        var streamUrl = $"{Http.BaseAddress}{Type}/apply/stream";

        try
        {
            var request = new System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Post, streamUrl);
            request.Content = System.Net.Http.Json.JsonContent.Create(toSync);
            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new System.IO.StreamReader(stream);

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line == null || !line.StartsWith("data: ")) continue;
                var json = line["data: ".Length..];
                var evt = System.Text.Json.JsonSerializer.Deserialize<ProgressEventDto>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (evt == null) continue;

                Progress = (startFrom + evt.Done, _syncIds.Count);
                _syncedIds = _syncIds.Take(Progress.Done).ToHashSet();
                await SaveSyncedAsync();

                if (evt.RateLimit)
                {
                    StateHasChanged();
                    return evt.WaitSeconds > 0 ? evt.WaitSeconds : 30;
                }

                if (evt.Error != null)
                {
                    ErrorMessage = evt.Error;
                    Status = SyncStatus.Error;
                    StateHasChanged();
                    return 0;
                }

                if (evt.Complete) Status = SyncStatus.Done;
                StateHasChanged();
            }

            if (Status == SyncStatus.Applying) Status = SyncStatus.Done;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Status = SyncStatus.Error;
        }

        StateHasChanged();
        return 0;
    }

    void Reset()
    {
        Status = SyncStatus.Idle;
        Results = new();
        Progress = (0, 0);
        ErrorMessage = null;
        _selected = new();
        _syncedIds = new();
        _syncIds = new();
        _previewRateLimited = false;
        _ = JS.InvokeVoidAsync("localStorage.removeItem", _listStorageKey);
        _ = JS.InvokeVoidAsync("localStorage.removeItem", _cacheStorageKey);
        _ = JS.InvokeVoidAsync("localStorage.removeItem", _excludedStorageKey);
        _ = JS.InvokeVoidAsync("localStorage.removeItem", _syncedStorageKey);
    }

    static string FormatCountdown(int seconds)
    {
        var h = seconds / 3600;
        var m = seconds % 3600 / 60;
        var s = seconds % 60;
        return h > 0 ? $"{h}:{m:D2}:{s:D2}" : $"{m}:{s:D2}";
    }

    // Cache helpers — persists found Spotify IDs and excluded selections in localStorage
    string _cacheStorageKey => $"backify_{Type}";
    string _excludedStorageKey => $"backify_{Type}_excluded";
    string _listStorageKey => $"backify_{Type}_list";
    string _syncedStorageKey => $"backify_{Type}_synced";
    static string CacheKey(string name, string artist) => $"{name.ToLowerInvariant()}|{artist.ToLowerInvariant()}";

    async Task<Dictionary<string, string>> LoadCacheAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", _cacheStorageKey);
            if (string.IsNullOrEmpty(json)) return new();
            return System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? new();
        }
        catch { return new(); }
    }

    async Task SaveCacheAsync()
    {
        try
        {
            var existing = await LoadCacheAsync();
            foreach (var r in Results.Where(r => r.Found && r.SpotifyId != null))
                existing[CacheKey(r.Name, r.Artist)] = r.SpotifyId!;
            await JS.InvokeVoidAsync("localStorage.setItem", _cacheStorageKey,
                System.Text.Json.JsonSerializer.Serialize(existing));
        }
        catch { }
    }

    async Task<HashSet<string>> LoadExcludedAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", _excludedStorageKey);
            if (string.IsNullOrEmpty(json)) return new();
            return System.Text.Json.JsonSerializer.Deserialize<HashSet<string>>(json) ?? new();
        }
        catch { return new(); }
    }

    async Task SaveExcludedAsync()
    {
        try
        {
            var excluded = Results
                .Where(r => r.Found && r.SpotifyId != null && !_selected.Contains(r.SpotifyId!))
                .Select(r => r.SpotifyId!)
                .ToHashSet();
            await JS.InvokeVoidAsync("localStorage.setItem", _excludedStorageKey,
                System.Text.Json.JsonSerializer.Serialize(excluded));
        }
        catch { }
    }

    async Task SaveSyncedAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", _syncedStorageKey,
                System.Text.Json.JsonSerializer.Serialize(_syncedIds));
        }
        catch { }
    }

    async Task<HashSet<string>> LoadSyncedAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", _syncedStorageKey);
            if (string.IsNullOrEmpty(json)) return new();
            return System.Text.Json.JsonSerializer.Deserialize<HashSet<string>>(json) ?? new();
        }
        catch { return new(); }
    }

    async Task SaveListAsync(List<ApiPreviewItem> items, int n, string period)
    {
        try
        {
            var dto = new ListCacheDto(n, period, items);
            await JS.InvokeVoidAsync("localStorage.setItem", _listStorageKey,
                System.Text.Json.JsonSerializer.Serialize(dto));
        }
        catch { }
    }

    async Task<ListCacheDto?> LoadListAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", _listStorageKey);
            if (string.IsNullOrEmpty(json)) return null;
            // Try new format first, fall back to old plain-array format
            try
            {
                return System.Text.Json.JsonSerializer.Deserialize<ListCacheDto>(json);
            }
            catch
            {
                var items = System.Text.Json.JsonSerializer.Deserialize<List<ApiPreviewItem>>(json);
                return items == null ? null : new ListCacheDto(N, Period, items);
            }
        }
        catch { return null; }
    }

    enum SyncStatus { Idle, Previewing, PreviewDone, Applying, RateLimited, Done, Error }

    record ApiPreviewItem(int Rank, string Name, string Artist, int PlayCount, string? SpotifyId, bool Found);
    record ListCacheDto(int N, string Period, List<ApiPreviewItem> Items);
    record ApiPreviewResponse(List<ApiPreviewItem> Items, int RateLimitSeconds);
    record ProgressEventDto(int Done, int Total, bool Complete, string? Error, bool RateLimit, int WaitSeconds);
    record SearchEventDto(string Type, SearchEventItem? Item, int WaitSeconds, string? ErrorMessage);
    record SearchEventItem(int Rank, string? SpotifyId, bool Found);
}
