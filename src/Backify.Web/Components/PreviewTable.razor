@if (Items.Count > 0)
{
    var found = Items.Count(i => i.Found);
    var searched = Items.Count(i => i.SearchStatus == SearchItemStatus.Done);
    var total = Items.Count;
    var notFound = Items.Count(i => i.SearchStatus == SearchItemStatus.Done && !i.Found);
    var synced = SyncedIds.Count;

    <div class="preview-summary">
        <span>
            @if (searched < total)
            {
                <span><span class="found">@found</span> found · <span style="color:var(--text-muted)">@searched/@total searched</span></span>
            }
            else
            {
                <span><span class="found">@found</span> of @total found on Spotify</span>
            }
        </span>
        <span style="display:flex;gap:.75rem;align-items:center">
            @if (Phase == TablePhase.Preview && notFound > 0)
            {
                <span class="not-found">@notFound not found</span>
            }
            @if (Phase == TablePhase.Preview)
            {
                var sel = Items.Count(i => i.Found && i.SpotifyId != null && Selected.Contains(i.SpotifyId!));
                <span class="selection-count">@sel selected</span>
            }
            @if (Phase is TablePhase.Applying or TablePhase.Done && synced > 0)
            {
                <span class="synced-count">@synced synced</span>
            }
        </span>
    </div>
    <div class="table-wrap">
        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@(Type == "tracks" ? "Track" : Type == "artists" ? "Artist" : "Album")</th>
                        @if (Type != "artists") { <th>Artist</th> }
                        <th>Plays</th>
                        <th style="text-align:right">@(Phase == TablePhase.Preview ? "Sync" : "Status")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        var isSynced = item.SpotifyId != null && SyncedIds.Contains(item.SpotifyId!);
                        var isSelected = item.SpotifyId != null && Selected.Contains(item.SpotifyId!);
                        var rowClass = item.SearchStatus == SearchItemStatus.Pending ? "row-pending" :
                            !item.Found ? "" :
                            isSynced ? "row-synced" :
                            Phase == TablePhase.Preview && !isSelected ? "row-skipped" : "";

                        <tr class="@rowClass">
                            <td class="td-rank">@item.Rank</td>
                            <td class="td-name">@item.Name</td>
                            @if (Type != "artists") { <td class="td-artist">@item.Artist</td> }
                            <td class="td-plays">@item.PlayCount.ToString("N0")</td>
                            <td class="td-status">
                                @if (item.SearchStatus == SearchItemStatus.Searching)
                                {
                                    <div class="spinner spinner-sm"></div>
                                }
                                else if (item.SearchStatus == SearchItemStatus.Pending)
                                {
                                    <span class="search-pending">···</span>
                                }
                                else if (!item.Found)
                                {
                                    <span class="badge badge-notfound">Not found</span>
                                }
                                else if (Phase == TablePhase.Preview)
                                {
                                    <input type="checkbox" class="sync-checkbox"
                                           checked="@isSelected"
                                           @onchange="() => OnToggle.InvokeAsync(item.SpotifyId!)" />
                                }
                                else if (isSynced)
                                {
                                    <span class="badge badge-synced">✓ Synced</span>
                                }
                                else if (Phase == TablePhase.Applying)
                                {
                                    <span class="badge badge-pending">Pending</span>
                                }
                                else
                                {
                                    <span class="badge badge-found">Found</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    [Parameter] public List<PreviewItemDto> Items { get; set; } = new();
    [Parameter] public string Type { get; set; } = "tracks";
    [Parameter] public TablePhase Phase { get; set; } = TablePhase.Preview;
    [Parameter] public HashSet<string> Selected { get; set; } = new();
    [Parameter] public HashSet<string> SyncedIds { get; set; } = new();
    [Parameter] public EventCallback<string> OnToggle { get; set; }

    public enum TablePhase { Preview, Applying, Done }
    public enum SearchItemStatus { Pending, Searching, Done }

    public record PreviewItemDto(int Rank, string Name, string Artist, int PlayCount, string? SpotifyId, bool Found, SearchItemStatus SearchStatus = SearchItemStatus.Done);
}
